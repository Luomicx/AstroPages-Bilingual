---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import { useTranslations, getLangPrefix, getLangFromUrl } from "@/i18n/ui";

export async function getStaticPaths() {
  return [
    { params: { lang: "en" } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const langPrefix = getLangPrefix(lang);

// Filter posts by language directory (e.g., "zh/" or "en/")
const allPosts = await getCollection("blog");
const posts = allPosts.filter(({ id }) => id.startsWith(`${lang}/`));

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

---

<Layout>
<Header lang={lang} />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <h1 class="reveal-item shimmer-title my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        {t("hero.greeting")}
      </h1>
      <a
        target="_blank"
        href={`${langPrefix}/rss.xml`}
        class="inline-block"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

      <p class="reveal-item">
        {t("hero.description")}
      </p>
      <p class="reveal-item mt-2">
        {t("hero.cta")}
        <LinkButton
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          href="https://github.com/t0saki/AstroPages-Bilingual#readme"
        >
          README
        </LinkButton>
      </p>
      {
        // only display if at least one social link is enabled
        SOCIALS.length > 0 && (
          <div class="reveal-item mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">{t("hero.socialLinks")}</div>
            <Socials />
          </div>
        )
      }
    </section>

    <section id="posts" class="pt-12 pb-6">
      <div class="timeline">
        <div class="timeline-line-fill"></div>
        {
          featuredPosts.map(data => (
            <div class="timeline-item featured">
              <div class="timeline-date">
                {data.data.modDatetime
                  ? new Date(data.data.modDatetime).toISOString().split("T")[0]
                  : new Date(data.data.pubDatetime).toISOString().split("T")[0]}
              </div>
              <Card variant="h3" {...data} />
            </div>
          ))
        }
        {
          recentPosts
            .slice(0, SITE.postPerIndex)
            .map(data => (
              <div class="timeline-item">
                <div class="timeline-date">
                  {data.data.modDatetime
                    ? new Date(data.data.modDatetime).toISOString().split("T")[0]
                    : new Date(data.data.pubDatetime).toISOString().split("T")[0]}
                </div>
                <Card variant="h3" {...data} />
              </div>
            ))
        }
      </div>
    </section>

    <div class="my-8 text-center">
      <LinkButton href={`${langPrefix}/posts/`}>
        {t("button.allPosts")}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer lang={lang} />
</Layout>

<style>
  /* ===== Scroll Reveal Hero ===== */
  .reveal-item {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-item.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-item:nth-child(1) { transition-delay: 0s; }
  .reveal-item:nth-child(2) { transition-delay: 0.12s; }
  .reveal-item:nth-child(3) { transition-delay: 0.24s; }
  .reveal-item:nth-child(4) { transition-delay: 0.36s; }

  /* ===== Shimmer Title ===== */
  .shimmer-title {
    background: linear-gradient(
      120deg,
      var(--foreground) 0%,
      var(--accent) 40%,
      var(--foreground) 60%,
      var(--accent) 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: shimmer 4s linear infinite;
  }

  @keyframes shimmer {
    to {
      background-position: 200% center;
    }
  }

  /* ===== Timeline Article List ===== */
  .timeline {
    position: relative;
    padding-left: 32px;
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: 6px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--border);
    border-radius: 1px;
  }

  .timeline-line-fill {
    position: absolute;
    left: 6px;
    top: 0;
    width: 2px;
    height: 0;
    background: var(--accent);
    border-radius: 1px;
    transition: height 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 1;
  }

  .timeline-line-fill.visible {
    height: 100%;
  }

  .timeline-item {
    position: relative;
    padding-bottom: 28px;
    opacity: 0;
    transform: translateX(-12px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .timeline-item.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .timeline-item::before {
    content: "";
    position: absolute;
    left: -28px;
    top: 8px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--background);
    border: 2px solid var(--border);
    transition: all 0.3s ease;
    z-index: 2;
  }

  .timeline-item.featured::before {
    border-color: var(--accent);
    background: var(--accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 15%, transparent);
  }

  .timeline-item:hover::before {
    transform: scale(1.3);
    border-color: var(--accent);
  }

  .timeline-date {
    font-size: 0.75rem;
    font-weight: 600;
    color: color-mix(in srgb, var(--foreground) 40%, transparent);
    letter-spacing: 0.03em;
    margin-bottom: 4px;
  }

  .timeline-item :global(.my-6) {
    margin-top: 0;
    margin-bottom: 0;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const mainContent = document.querySelector("#main-content") as HTMLElement;
    const indexLayout = mainContent?.dataset?.layout;
    if (indexLayout) {
      const currentPath = window.location.pathname;
      const backUrl = currentPath.startsWith('/en') ? '/en/' : '/';
      sessionStorage.setItem("backUrl", backUrl);
    }

    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );

    document.querySelectorAll(".reveal-item").forEach(el => observer.observe(el));

    document.querySelectorAll(".timeline-item").forEach((el, i) => {
      (el as HTMLElement).style.transitionDelay = `${i * 0.1}s`;
      observer.observe(el);
    });

    document.querySelectorAll(".timeline-line-fill").forEach(el => observer.observe(el));
  });
</script>

